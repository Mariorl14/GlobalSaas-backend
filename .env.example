DATABASE_URL=postgresql://username:password@localhost:5432/database_name
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRES_HOURS=1
SUPERADMIN_SEED_TOKEN=93b7fa3a-83f4-4226-bf12-ee27dbf54445

# Email appointment confirmations (SMTP — Brevo, SendGrid, Gmail app password, etc.)
EMAIL_NOTIFICATIONS_ENABLED=false
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com
MAIL_DEFAULT_SENDER_NAME=Barber Suite
MAIL_TIMEOUT=15

# WhatsApp appointment confirmations (Twilio) — disabled for now; enable later
WHATSAPP_NOTIFICATIONS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox example: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Approved WhatsApp template Content SID (utility)
TWILIO_WHATSAPP_CONTENT_SID=
# ISO 3166-1 alpha-2 fallback when business.country_code is unset (e.g. CR, MX, US)
DEFAULT_PHONE_COUNTRY_CODE=
TWILIO_REQUEST_TIMEOUT=10
